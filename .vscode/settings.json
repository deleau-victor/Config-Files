{
    // *******************************************
    // ************ Workbench Config *************
    // *******************************************
    "workbench.activityBar.location": "top",
    "workbench.colorTheme": "One Dark Pro Darker",
    "workbench.iconTheme": "material-icon-theme",
    "workbench.productIconTheme": "jetbrains-idea-product-icon-theme",
    "workbench.tree.indent": 22,
    "workbench.tree.renderIndentGuides": "always",
    "workbench.editorAssociations": {
        "*.copilot.md": "vscode.markdown.preview.editor",
        "*.svg": "default"
    },
    "custom-ui-style.external.imports": [
        "file:///C:/Users/Victor/.vscode/extensions/ui-patch/css.css",
        "file:///C:/Users/Victor/.vscode/extensions/ui-patch/js.js"
    ],
    "custom-ui-style.external.loadStrategy": "cache",
    "notebook.diff.enablePreview": false,
    // *******************************************
    // ************** Editor Config **************
    // *******************************************
    "editor.acceptSuggestionOnCommitCharacter": false,
    "editor.accessibilitySupport": "off",
    "editor.cursorBlinking": "solid",
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "[csharp]": {
        "editor.defaultFormatter": "ms-dotnettools.csharp"
    },
    "editor.fontFamily": "'Monolisa'",
    "editor.fontLigatures": true,
    "editor.fontSize": 14,
    "editor.fontWeight": "normal",
    "editor.formatOnSave": true,
    "editor.guides.bracketPairs": true,
    "editor.guides.indentation": false,
    "editor.inlayHints.enabled": "off",
    "editor.inlineSuggest.enabled": true,
    "editor.inlineSuggest.showToolbar": "always",
    "editor.lineHeight": 22,
    "editor.linkedEditing": true,
    "editor.minimap.enabled": false,
    "editor.renderWhitespace": "trailing",
    "editor.snippetSuggestions": "inline",
    "editor.suggest.insertMode": "replace",
    "editor.tabSize": 4,
    "editor.wordWrap": "on",
    "editor.wordWrapColumn": 120,
    // *******************************************
    // *********** Diff Editor Config ************
    // *******************************************
    "diffEditor.wordWrap": "on",
    // *******************************************
    // ************** Files Config ***************
    // *******************************************
    "files.autoSave": "onFocusChange",
    "files.eol": "\n",
    "files.exclude": {
        "**/.git": true,
        "**/.svn": true,
        "**/.hg": true,
        "**/CVS": true,
        "**/.DS_Store": true,
        "**/Thumbs.db": true,
        "**/bin/**": true,
        "**/obj/**": true
    },
    "files.associations": {
        "*.json": "jsonc"
    },
    // *******************************************
    // ************* Explorer Config *************
    // *******************************************
    "explorer.autoReveal": false,
    "explorer.confirmDelete": false,
    "explorer.confirmDragAndDrop": false,
    "explorer.compactFolders": false,
    // *******************************************
    // ************ Javascript Config ************
    // *******************************************
    "javascript.updateImportsOnFileMove.enabled": "always",
    "typescript.updateImportsOnFileMove.enabled": "always",
    "vue.updateImportsOnFileMove.enabled": true,
    // *******************************************
    // ************** Emmet Config ***************
    // *******************************************
    "emmet.triggerExpansionOnTab": true,
    // *******************************************
    // *************** Git Config ****************
    // *******************************************
    "git.autofetch": true,
    "git.confirmSync": false,
    "git.enableSmartCommit": true,
    // "git.path": "\\\\wsl.localhost\\Ubuntu-24.04\\usr\\bin\\git", => If you want to use WSL git
    // *******************************************
    // ************* Prettier Config *************
    // *******************************************
    "prettier.arrowParens": "always",
    "prettier.bracketSpacing": true,
    "prettier.printWidth": 120,
    "prettier.semi": true,
    "prettier.singleQuote": false,
    "prettier.useTabs": false,
    "prettier.endOfLine": "lf",
    // *******************************************
    // ************* Material Config *************
    // *******************************************
    "material-icon-theme.hidesExplorerArrows": true,
    "material-icon-theme.activeIconPack": "vue_vuex",
    "material-icon-theme.folders.theme": "specific",
    "material-icon-theme.folders.associations": {
        "features": "App",
        "stores": "Ngrx-store",
        "http": "Api",
        "Converters": "pipe",
        "Endpoints": "Api",
        "Abstractions": "Base",
        "Persistence": "Database",
        "DependencyInjection": "../../../../custom-icons/folder-injection",
        "Commands": "../../../../custom-icons/folder-command",
        "Queries": "../../../../custom-icons/folder-query",
        "Caching": "../../../../custom-icons/folder-redis"
    },
    "material-icon-theme.files.associations": {
        "*.store.ts": "Angular-resolver",
        "*.cs": "../../custom-icons/csharp",
        "*.Tests.cs": "../../custom-icons/test-cs"
    },
    // *******************************************
    // ************* Terminal Config *************
    // *******************************************
    "terminal.integrated.defaultProfile.windows": "Zsh",
    "terminal.integrated.fontFamily": "MesloLGS NF",
    "terminal.integrated.profiles.windows": {
        "Command Prompt": {
            "path": ["${env:windir}\\Sysnative\\cmd.exe", "${env:windir}\\System32\\cmd.exe"],
            "args": [],
            "icon": "terminal-cmd"
        },
        "Git Bash": {
            "source": "Git Bash"
        },
        "PowerShell": {
            "source": "PowerShell",
            "icon": "terminal-powershell"
        },
        "Zsh": {
            "path": "C:\\windows\\System32\\wsl.exe",
            "args": ["-d", "Ubuntu-24.04"],
            "icon": "terminal-ubuntu",
            "overrideName": true
        }
    },
    // *******************************************
    // ************* Security Config *************
    // *******************************************
    "security.allowedUNCHosts": ["wsl.localhost"],
    "security.workspace.trust.untrustedFiles": "open",
    // *******************************************
    // ************** CSpell Config **************
    // *******************************************
    "cSpell.language": "en,fr",
    // *******************************************
    // *************** HTTP Config ***************
    // *******************************************
    "http.proxyStrictSSL": false,
    "http.proxy": null,
    // *******************************************
    // ********** Better Comment Config **********
    // *******************************************
    "better-comments.tags": [
        {
            "tag": "!",
            "color": "#FF2D00",
            "strikethrough": false,
            "underline": false,
            "backgroundColor": "transparent",
            "bold": false,
            "italic": false
        },
        {
            "tag": "?",
            "color": "#3498DB",
            "strikethrough": false,
            "underline": false,
            "backgroundColor": "transparent",
            "bold": false,
            "italic": false
        },
        {
            "tag": "//",
            "color": "#474747",
            "strikethrough": true,
            "underline": false,
            "backgroundColor": "transparent",
            "bold": false,
            "italic": false
        },
        {
            "tag": "todo",
            "color": "#FF8C00",
            "strikethrough": false,
            "underline": false,
            "backgroundColor": "transparent",
            "bold": false,
            "italic": false
        },
        {
            "tag": "*",
            "color": "#98C379",
            "strikethrough": false,
            "underline": false,
            "backgroundColor": "transparent",
            "bold": false,
            "italic": false
        },
        {
            "tag": "#region",
            "color": "#FF8C00",
            "strikethrough": false,
            "underline": false,
            "backgroundColor": "transparent",
            "bold": false,
            "italic": false
        },
        {
            "tag": "#endregion",
            "color": "#FF8C00",
            "strikethrough": false,
            "underline": false,
            "backgroundColor": "transparent",
            "bold": false,
            "italic": false
        }
    ],
    // *******************************************
    // ************* LLM Chat Config *************
    // *******************************************
    "claudeCode.preferredLocation": "sidebar",
    "chat.viewSessions.orientation": "stacked",
    "github.copilot.enable": {
        "*": true,
        "plaintext": false,
        "scminput": false
    },
    // *******************************************
    // ************* JS Tests Config *************
    // *******************************************
    "jest.runMode": "on-demand",
    // *******************************************
    // ************** Remote Config **************
    // *******************************************
    "remote.autoForwardPortsSource": "hybrid",
    "remote.SSH.remotePlatform": {
        // "my-remote-server": "linux"
    },
    // *******************************************
    // ********* Project Manager Config **********
    // *******************************************
    "projectManager.tags": []
    // *******************************************
    // ********* Workbench color Config **********
    // *******************************************
}
